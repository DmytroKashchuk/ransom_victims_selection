  "group": "threeam",
  "description": "A new Ransomware family identified by the name '3AM' or 'ThreeAM' in September 2023. The ransomware operation was observed by the Symantec team, in which a ransomware affiliate attempted to deploy another ransomware, LockBit, on the target network and then switched to 3AM when LockBit was reportedly blocked.<BR> \n> <BR> \n> The ransomware operation, according to the publication on its Tor-based website, has been operating since mid-August 2023, according to the publication from its first victim.<BR>Source: https://github.com/crocodyli/ThreatActors-TTPs",
  "added_date": null,
  "victims": 64,
  "firstseen": "2023-08-04",
  "lastseen": "2025-05-25",
  "ttps": [
    {
      "tactic_id": "TA0003",
      "tactic_name": "Persistence",
      "techniques": [
        {
          "technique_name": "Create Account",
          "technique_id": "T1136",
          "technique_details": "The threat actor using the 3AM ransomware performed account creation to ensure persistence."
        }
      ]
    },
    {
      "tactic_id": "TA0004",
      "tactic_name": "Privilege Escalation",
      "techniques": [
        {
          "technique_name": "Bypass User Account Control",
          "technique_id": "T1548.002",
          "technique_details": "The threat actor may use Cobalt Strike for a series of known techniques to bypass Windows UAC."
        },
        {
          "technique_name": "Service Execution",
          "technique_id": "T1543.003",
          "technique_details": "The threat actor used PsExec to take advantage of a Windows service to escalate from administrator privileges to SYSTEM."
        }
      ]
    },
    {
      "tactic_id": "TA0005",
      "tactic_name": "Defense Evasion",
      "techniques": [
        {
          "technique_name": "Disable or Modify System Firewall Settings",
          "technique_id": "T1562.004",
          "technique_details": "The threat actor uses commands to set the discovery policy of other hosts on the network, altering the Firewall policy."
        },
        {
          "technique_name": "Clear Windows Event Logs",
          "technique_id": "T1070.001",
          "technique_details": "The executable clears Windows event logs after its execution."
        }
      ]
    },
    {
      "tactic_id": "TA0007",
      "tactic_name": "Discovery",
      "techniques": [
        {
          "technique_name": "Network Share Discovery",
          "technique_id": "T1135",
          "technique_details": "The threat actor executed reconnaissance commands like 'whoami, netstat, quser, net view, and net share' to enumerate other servers."
        },
        {
          "technique_name": "Group Policy Discovery",
          "technique_id": "T1615",
          "technique_details": "The threat actor used commands like 'gpresult' to dump applied policy settings on the computer for a user (Group Policy)."
        },
        {
          "technique_name": "Remote System Discovery",
          "technique_id": "T1018",
          "technique_details": "Utilizes Advanced IP Scanner and MASSCAN to discover remote systems."
        }
      ]
    },
    {
      "tactic_id": "TA0010",
      "tactic_name": "Exfiltration",
      "techniques": [
        {
          "technique_name": "Exfiltration Over Alternative Protocol",
          "technique_id": "T1048",
          "technique_details": "The threat actor used the 'Wput' tool to exfiltrate files from the victim to their own server via FTP."
        }
      ]
    },
    {
      "tactic_id": "TA0040",
      "tactic_name": "Impact",
      "techniques": [
        {
          "technique_name": "Inhibit System Recovery",
          "technique_id": "T1490",
          "technique_details": "The 3AM ransomware deletes volume shadow copies on the disk and backups through the commands presented in the analysis."
        },
        {
          "technique_name": "Data Encrypted for Impact",
          "technique_id": "T1486",
          "technique_details": "The ransomware encrypts files and appends the '.threeamtime' extension after encryption."
        }
      ]
    }
